# Brasse-Bouillon API — Docker / production environment template
# Copy to .env and fill in real values before running docker compose.
# Never commit the .env file.

# Runtime
NODE_ENV=production
APP_ENV=production

# HTTP
PORT=3000

# Docker image tag (used by docker-compose.yml). Default: latest.
# For production, pin to an immutable tag (e.g. API_IMAGE_TAG=sha-a1b2c3d).
API_IMAGE_TAG=latest

# JWT (required — generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_min_32_chars
JWT_EXPIRATION=86400s

# Database — path inside the container (persisted via the api-data volume)
DATABASE_PATH=/app/data/brasse-bouillon.db
TYPEORM_MIGRATIONS_RUN=true
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# Swagger — disabled in production
SWAGGER_ENABLED=false

# Seed endpoints — disabled in production
SEED_ENDPOINTS_ENABLED=false
SEED_ENDPOINTS_TOKEN=

# Water provider (Hubeau)
WATER_PROVIDER_DEFAULT=hubeau
HUBEAU_BASE_URL=https://hubeau.eaufrance.fr/api/v1/qualite_eau_potable
HUBEAU_TIMEOUT_MS=8000
HUBEAU_CACHE_TTL_SECONDS=3600
HUBEAU_MAX_SAMPLES=50
HUBEAU_COMMUNES_UDI_SIZE=10
HUBEAU_RESULTATS_DIS_SIZE=100
