# Brasse-Bouillon Backend — test example
# Usage: copy to .env.test only if you want to override
# values already injected by npm test scripts.

# Runtime environment
APP_ENV=test
NODE_ENV=test

# JWT security (required)
JWT_SECRET=test_jwt_secret_key_change_me
JWT_EXPIRATION=86400s

# Database (isolated tests)
DATABASE_PATH=:memory:
TYPEORM_LOGGING=false

# API/Docs
PORT=3000
SWAGGER_ENABLED=false

# Hubeau (stable tunables for tests)
HUBEAU_TIMEOUT_MS=3000
HUBEAU_CACHE_TTL_SECONDS=60
