    "hero.title": {
      "en": "Brew your first beer <em>without fear of messing it up.</em>",
      "srcHash": "840ffe7d5114a8b1d80f9ab6183b4f3ae3c24d51"
    },
    "hero.intro": {
      "en": "From the recipe you pick to your first sip, the app tells you what to do, when, and why. No jargon, no mental math, no nasty surprises.",
      "srcHash": "4bb792cabb23a13e89efa786f4399d613be230b9"
    },
    "hero.cta.primary": {
      "en": "Join the waitlist",
      "srcHash": "9c2b4ba2ab2b045e352a40d41d60375bdb35a6dd"
    },
    "hero.cta.secondary": {
      "en": "See how it goes",
      "srcHash": "e844e5f38501cd4ed4974931b7c9afa7d76ca4d0"
    },
    "hero.mascot": {
      "en": "Brasse-Bouillon official mascot",
      "srcHash": "f5918f508f71f1965082c01739f4cc72af11f96d"
    },
    "journey.eyebrow": {
      "en": "The journey",
      "srcHash": "b9d81891c45c73ec3273ed76ad3fad006ecc7960"
    },
    "journey.title": {
      "en": "From recipe to <em>first pour</em>",
      "srcHash": "350295349876d5fa05be97100d5307aabd72777f"
    },
    "journey.intro": {
      "en": "Four steps, a copilot at every moment. You’re never left alone in front of the kettle.",
      "srcHash": "bac252e2ef02f310edd52db277a2fe73f04afa58"
    },
    "journey.1.img": {
      "en": "App recipe catalog: a list of public recipes with their IBU, ABV and volume figures",
      "srcHash": "6528264a06d5fe4a6a4edd77003d98422d2722a9"
    },
    "journey.1.title": {
      "en": "Pick your recipe",
      "srcHash": "3b59041f30967e4ff04d828315b2aed6249c7465"
    },
    "journey.1.body": {
      "en": "Compare the community’s clone recipes — rated and battle-tested — and adopt the one that tempts you. No jargon.",
      "srcHash": "ed856fa092db692ce1fde534f663a30e8756f457"
    },
    "journey.2.img": {
      "en": "Brew-day control screen during the mash at 67°C, with a timer and steps",
      "srcHash": "42023a79006945cc4f71bc26a4da3cd953a550ca"
    },
    "journey.2.title": {
      "en": "Brew step by step",
      "srcHash": "0168728f5bf92604842c6149856fcf9834c64821"
    },
    "journey.2.body": {
      "en": "Timers, temperatures and the why behind every move: the app guides you through mash, boil and chill.",
      "srcHash": "e7ae56a565b4b98eb0b861371631f0fb34383c4d"
    },
    "journey.3.img": {
      "en": "Fermentation screen with a day 5 of 14 progress bar and the current gravity",
      "srcHash": "6c868c8f256f30b860b60354473810c8cad90329"
    },
    "journey.3.title": {
      "en": "Track fermentation",
      "srcHash": "830a6feb28eacf6816a88a35e44d132e731d1b9f"
    },
    "journey.3.body": {
      "en": "Days, gravity, temperature. One glance and you know where you stand.",
      "srcHash": "39ecfd8acf3dbe5a111b40167c6d6f6e05737de9"
    },
    "journey.4.img": {
      "en": "‘Batch complete’ celebration screen with the bottle and a custom label",
      "srcHash": "ede4db4df83e2931aa99a93302ec9999223b18e5"
    },
    "journey.4.title": {
      "en": "Bottle it, savor it",
      "srcHash": "ebd1cb34b4754f03653d6f2e6ac604c7428bae04"
    },
    "journey.4.body": {
      "en": "Slap on your label, share with friends, and enjoy your first creation.",
      "srcHash": "7bfc60d8fc55433b4e0ceaf18627f85bb343faea"
    },
