tree.txt

# Design assets policy: PNGs under docs/design/ are tracked but must stay
# under 2 MB each to keep Claude Code API requests below the 32 MB limit.
# Run tools/compress-design-pngs.py on any new addition. See docs/design/README.md.

# Local working docs (AI/notes)
Guide_Complet_Calculs_Brassage_*.md
Chapitre*_*.md

# External reference material — tracked as local copies only, never
# versioned. Files we consult for product / encyclopedia / scan work but
# that we do not own (copyright stays with the original publisher).
# Examples: BrewDog's DIY DOG recipe book, brewery decks, datasheets,
# images, archives, etc.
#
# Ignore everything in the folder by default, then re-include only the
# tracked metadata files (README). This is broader than a `*.pdf` rule
# and covers the full "PDFs and assets" scope described in the README:
# zip archives, images, mp4 walkthroughs, anything a contributor might
# legitimately drop in for reference.
docs/product/references/*
!docs/product/references/README.md

# Misc
.cache/
.temp
.tmp

# ===========================
# Claude Code harness — local-only files
# ===========================
# `.claude/settings.json` carries machine-specific allow-lists (absolute
# paths, personal email) that the harness updates whenever a Bash
# command is approved. `.claude/scheduled_tasks.lock` is a runtime
# lock file used by the ScheduleWakeup mechanism. Both are
# per-machine: tracking them pollutes diffs and leaks PII. Anything
# else under `.claude/` (e.g. a future shared `CLAUDE.md`) stays
# trackable.
.claude/settings.json
.claude/scheduled_tasks.lock
.claude/settings.json
