# ===========================
# Node / npm
# ===========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tgz
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
# npm workspaces — only the root package-lock.json is canonical.
# Per-package lockfiles drift silently (we caught one in #674 still
# named brasse-bouillon-frontend, pre-monorepo). Block them at source.
packages/*/package-lock.json

