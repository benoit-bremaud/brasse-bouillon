{
  "name": "brasse-bouillon-backend",
  "version": "0.1.14-alpha1",
  "engines": {
    "node": ">=20 <21"
  },
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/AutoMigration",
    "migration:create": "npm run typeorm -- migration:create src/database/migrations/ManualMigration",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "cross-env APP_ENV=test NODE_ENV=test JWT_SECRET=test_jwt_secret_key_change_me JWT_EXPIRATION=86400s jest",
    "test:protected": "cross-env APP_ENV=test NODE_ENV=test DATABASE_PATH=:memory: JWT_SECRET=test_jwt_secret_key_change_me JWT_EXPIRATION=86400s TYPEORM_SYNCHRONIZE=false TYPEORM_MIGRATIONS_RUN=true jest --config ./test/jest-e2e.json test/auth.protected.e2e-spec.ts --runInBand",
    "test:watch": "cross-env APP_ENV=test NODE_ENV=test JWT_SECRET=test_jwt_secret_key_change_me JWT_EXPIRATION=86400s jest --watch",
    "test:cov": "cross-env APP_ENV=test NODE_ENV=test JWT_SECRET=test_jwt_secret_key_change_me JWT_EXPIRATION=86400s jest --coverage",
    "test:debug": "cross-env APP_ENV=test NODE_ENV=test JWT_SECRET=test_jwt_secret_key_change_me JWT_EXPIRATION=86400s node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env APP_ENV=test NODE_ENV=test DATABASE_PATH=:memory: JWT_SECRET=test_jwt_secret_key_change_me JWT_EXPIRATION=86400s TYPEORM_SYNCHRONIZE=false TYPEORM_MIGRATIONS_RUN=true jest --config ./test/jest-e2e.json",
    "eval:faq-bot": "cross-env TS_NODE_COMPILER_OPTIONS={\\\"module\\\":\\\"CommonJS\\\"} ts-node src/faq-bot/evals/prompt-tdd.eval.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "altcha-lib": "^2.3.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^17.13.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.31"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.(t|j)s",
      "!**/*.e2e-spec.(t|j)s",
      "!**/database/migrations/**"
    ],
    "coverageDirectory": "../coverage",
    "coverageReporters": [
      "lcov",
      "text",
      "text-summary"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "branches": 72,
        "functions": 85,
        "lines": 90
      }
    },
    "testEnvironment": "node"
  }
}
