{
  "expo": {
    "name": "Brasse Bouillon",
    "slug": "brasse-bouillon-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brasse-bouillon-logo-primary-512.png",
    "scheme": "brassebouillonfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.brassebouillon.mobileapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brasse-bouillon-logo-primary-512.png",
        "backgroundColor": "#F5D547"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a527c490-36e1-49f2-a91b-5866a2823b5f"
      }
    },
    "owner": "beniot",
    "updates": {
      "url": "https://u.expo.dev/a527c490-36e1-49f2-a91b-5866a2823b5f"
    }
  }
}
