    "features.eyebrow": {
      "en": "Three tools, one copilot",
      "srcHash": "e7e14ee261ea81c8cff9ee170aa6ffb6c6c29287"
    },
    "features.title": {
      "en": "The <em>essentials</em>, and nothing but",
      "srcHash": "7cfe10f1a00aa3edb6135521c3a2eca62f3fcc94"
    },
    "features.intro": {
      "en": "No feature bloat. Three pillars, built to save you time and help you level up.",
      "srcHash": "05f2253af8ff659fe60ee98cede15c53700faf9b"
    },
    "features.1.img": {
      "en": "Recipe Studio screen with Ingredients tabs and live calculations",
      "srcHash": "7d32aa98e1c5088b777b434dfbf2b2e1bd908c01"
    },
    "features.1.title": {
      "en": "Recipe studio",
      "srcHash": "d422901e89b4ee40ede6a66c3e36493b958b10fd"
    },
    "features.1.body": {
      "en": "Create, clone and tweak your recipes in a few taps. Version and compare without losing the thread.",
      "srcHash": "8404f8abde036ddcc6dd6aacd99dba862e7ef757"
    },
    "features.2.img": {
      "en": "Hop calculator screen with Quick, Reverse and BU:GU tabs and interactive sliders",
      "srcHash": "87a7484842ad76ecce845fb7be8dd7c12dfc161b"
    },
    "features.2.title": {
      "en": "Brewing calculators",
      "srcHash": "685b231279bd01c446d5cb6860c0fdb84a6c6473"
    },
    "features.2.body": {
      "en": "IBU, ABV, color, volumes, efficiency. Every number in one place, and reliable.",
      "srcHash": "da9339d475905b61e29d8d3e22ca0a4ccc907a5a"
    },
    "features.3.img": {
      "en": "Real-time brew control screen with a step timeline and statuses",
      "srcHash": "bb2c6c45c640614bdd8dd5f67c87febba503b164"
    },
    "features.3.title": {
      "en": "Guided brew control",
      "srcHash": "23a1d154b09e1a4b11a99d9e32ee60d2c12d54eb"
    },
    "features.3.body": {
      "en": "A clear timeline, useful reminders, critical checkpoints. You know what to do, when, and why.",
      "srcHash": "6b4a40eeb97a178abf768cffe08d0e2742ab1b04"
    },
    "scan.eyebrow": {
      "en": "Recognition",
      "srcHash": "c39abf968438238b9d5e3c1cfcdac492c27a3f17"
    },
    "scan.title": {
      "en": "Loved a beer?&nbsp;<em>Scan it.</em>",
      "srcHash": "fe435adcf423205b4cb3fa54f4ab9851819645b4"
    },
    "scan.intro": {
      "en": "Scan the label of a store-bought beer&nbsp;: Brasse-Bouillon identifies it, then suggests equivalent recipes rated by the community — ready to brew.",
      "srcHash": "171a89e1a2fbf0c4c4bdf6154245b641b7a91171"
    },
    "scan.1.img": {
      "en": "Recognized-beer screen showing La Chouffe with its style, color and bitterness",
      "srcHash": "d7d0b61345c97e1d6e0fae54ff9b85de218f7ef0"
    },
    "scan.1.title": {
      "en": "Instant recognition",
      "srcHash": "ae73a623563782b1d4a1177340b2223b59111b84"
    },
    "scan.1.body": {
      "en": "Style, color, bitterness, ABV&nbsp;: the full profile the moment the beer is identified.",
      "srcHash": "d87610128317b988a2d70b0242b0d879b0a5befa"
    },
    "scan.2.img": {
      "en": "Equivalent community-rated recipes, each with an Import button",
      "srcHash": "c1a8b772cfc7f4aef28ca049e5cf5f8d70e37f9c"
    },
    "scan.2.title": {
      "en": "Community recipes",
      "srcHash": "911d4e163b5812334da9727d10e08a595e2f029d"
    },
    "scan.2.body": {
      "en": "Clones rated and proven by other brewers — import them into your notebook in one tap.",
      "srcHash": "387a9bca79722b8251bed972f95e2700201e49ca"
    },
    "faq.eyebrow": {
      "en": "Frequently asked",
      "srcHash": "16664684bf730f9eab647d82781e59a3e7e93706"
    },
    "faq.title": {
      "en": "The <em>doubts</em> before you dive in",
      "srcHash": "46e20938b1b1ec576558595b55e1d6860c1c29be"
    },
    "faq.q1.summary": {
      "en": "Do I need to be handy to brew my own beer?",
      "srcHash": "19f164c5b9254752d7eb17b5f181207d061f79a4"
    },
    "faq.q1.answer": {
      "en": "Not at all. A pot, a fermenter, some bottles — and the app telling you what to do at every step. If you can cook pasta, you can brew a beer.",
      "srcHash": "6ae50d4e84a1d7efbda08422530c86dcbe0d398c"
    },
    "faq.q2.summary": {
      "en": "How much does it cost to get started?",
      "srcHash": "8096f00f68bbd57dbe236430647008def460b4fe"
    },
    "faq.q2.answer": {
      "en": "Roughly €60–120 for a complete starter kit. You’ll reuse it for 5–6 batches, and the gear pays for itself fast compared with buying good craft beer.",
      "srcHash": "c162fe38065d03546edb5676dda6f5ca6f3eb0d4"
    },
    "faq.q3.summary": {
      "en": "How long does a batch take (the first time)?",
      "srcHash": "9ce10650827d4d31df87db93d145a81ebfd3e430"
    },
    "faq.q3.answer": {
      "en": "Half a day for the brew session (4–5h), then 2 to 3 weeks of fermentation where you’ve got almost nothing to do. The app reminds you of the critical checkpoints.",
      "srcHash": "15d8a979d57a32d84996ddad793d8c29f2e6db09"
    },
    "faq.q4.summary": {
      "en": "And if I botch my first batch?",
      "srcHash": "4651d4798bb65222ec6a683fddbb4a16a114e10f"
    },
    "faq.q4.answer": {
      "en": "It happens, and it’s almost always drinkable. The app walks back through each step to help you understand what happened — and your next batch comes out better.",
      "srcHash": "d64a6327c29556ba44907fced3634c46370b1c13"
    },
    "faq.q5.summary": {
      "en": "When will the app be available?",
      "srcHash": "63b9f9c257bb169a18b6b6f198109ff754e94b09"
    },
    "faq.q5.answer": {
      "en": "A rolling beta through 2026. Waitlist signups get first access.",
      "srcHash": "2f180197e73a4850828312ee7f0cfe8b32665c1d"
    },
    "participate.eyebrow": {
