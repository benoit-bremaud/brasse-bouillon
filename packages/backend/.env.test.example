# Brasse-Bouillon Backend — test example
# Usage: copy to .env.test only if you want to override
# values already injected by npm test scripts.

# Runtime environment
APP_ENV=test
NODE_ENV=test

# JWT security (required)
JWT_SECRET=test_jwt_secret_key_change_me
JWT_EXPIRATION=86400s

# Database (isolated tests)
DATABASE_PATH=:memory:
TYPEORM_MIGRATIONS_RUN=true
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# API/Docs
PORT=3000
SWAGGER_ENABLED=false

# Seed disabled in tests
SEED_ENDPOINTS_ENABLED=false
SEED_ENDPOINTS_TOKEN=

# Water provider (stable values for tests)
WATER_PROVIDER_DEFAULT=hubeau
HUBEAU_TIMEOUT_MS=3000
HUBEAU_CACHE_TTL_SECONDS=60
HUBEAU_MAX_SAMPLES=10
HUBEAU_COMMUNES_UDI_SIZE=3
HUBEAU_RESULTATS_DIS_SIZE=20