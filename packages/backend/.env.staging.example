# Brasse-Bouillon Backend — staging example
# Staging runs the app in a production-like mode.
# Real values must be injected through CI/CD (GitHub Environments/Secrets).

# Runtime environment
APP_ENV=staging
NODE_ENV=production

# JWT security (required)
JWT_SECRET=replace-with-a-long-random-secret-min-24-chars
JWT_EXPIRATION=86400s

# API HTTP
PORT=3000

# Database
# For staging with SQLite (school server), keep this path.
# For PostgreSQL, provide dedicated DB variables on the deployment platform.
DATABASE_PATH=./data/brasse-bouillon-staging.db
TYPEORM_MIGRATIONS_RUN=true
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# Docs API
SWAGGER_ENABLED=false

# Seed: always disabled outside development
SEED_ENDPOINTS_ENABLED=false
SEED_ENDPOINTS_TOKEN=

# Water provider
WATER_PROVIDER_DEFAULT=hubeau
HUBEAU_BASE_URL=https://hubeau.eaufrance.fr/api/v1/qualite_eau_potable
HUBEAU_TIMEOUT_MS=8000
HUBEAU_CACHE_TTL_SECONDS=1800
HUBEAU_MAX_SAMPLES=50
HUBEAU_COMMUNES_UDI_SIZE=10
HUBEAU_RESULTATS_DIS_SIZE=100
