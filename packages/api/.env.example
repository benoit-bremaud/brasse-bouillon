# Brasse-Bouillon Backend — local example (development)
# Copy this file to .env.local, then adjust values for your machine.
# Never commit real secrets.

# Runtime environment
APP_ENV=development
NODE_ENV=development

# JWT security (required)
JWT_SECRET=replace-with-a-long-random-secret-min-24-chars
JWT_EXPIRATION=86400s

# API HTTP
PORT=3000

# Database (SQLite)
DATABASE_PATH=./data/brasse-bouillon.db
TYPEORM_MIGRATIONS_RUN=true
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=true

# Swagger (enabled locally)
SWAGGER_ENABLED=true

# Seed endpoints (development only)
SEED_ENDPOINTS_ENABLED=false
SEED_ENDPOINTS_TOKEN=

# Water provider (Hubeau)
WATER_PROVIDER_DEFAULT=hubeau
HUBEAU_BASE_URL=https://hubeau.eaufrance.fr/api/v1/qualite_eau_potable
HUBEAU_TIMEOUT_MS=8000
HUBEAU_CACHE_TTL_SECONDS=3600
HUBEAU_MAX_SAMPLES=50
HUBEAU_COMMUNES_UDI_SIZE=10
HUBEAU_RESULTATS_DIS_SIZE=100
